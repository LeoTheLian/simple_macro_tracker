# Copy this to .env and fill in your values
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,simple-macro-tracker.onrender.com
CSRF_TRUSTED_ORIGINS=https://simple-macro-tracker.onrender.com

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/macro_tracker

# USDA FoodData Central API key
# Get a free key at https://api.data.gov/signup/
# Use DEMO_KEY for initial testing (lower rate limits)
USDA_API_KEY=DEMO_KEY
